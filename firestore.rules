rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definition
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // Simplistic admin check based on email
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "nakibprince666@gmail.com";
    }

    match /universities/{universityId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(universityId);
      allow update: if isAdmin() && isValidId(universityId);
      allow delete: if isAdmin() && isValidId(universityId);
    }

    match /programs/{programId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(programId);
      allow update: if isAdmin() && isValidId(programId);
      allow delete: if isAdmin() && isValidId(programId);
    }
  }
}
